PORT=4000
NODE_ENV=development
CORS_ORIGIN=https://exapts-frontend.vercel.app

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
ADMIN_SESSION_SECRET=change-me-to-a-second-long-random-string
ADMIN_SESSION_EXPIRES_IN=30m
PARTNER_JWT_SECRET=change-me-to-a-partner-long-random-string
PARTNER_JWT_EXPIRES_IN=7d

# Postgres
DATABASE_URL=postgresql://omega:omega@postgres:5432/omega?schema=public

# Redis (cache + BullMQ)
# REDIS_URL=redis://redis:6379
REDIS_URL = rediss://default:********@magnetic-pony-133429.upstash.io:6379
# Mail (mock pour démo, swap pour Resend/Sendgrid en prod)
MAIL_FROM="OMEGA <no-reply@omega.mu>"
MAIL_TRANSPORT=log
