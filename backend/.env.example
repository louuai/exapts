PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Postgres
DATABASE_URL=postgresql://omega:omega@postgres:5432/omega?schema=public

# Redis (cache + BullMQ)
REDIS_URL=redis://redis:6379

# Mail (mock pour démo, swap pour Resend/Sendgrid en prod)
MAIL_FROM="OMEGA <no-reply@omega.mu>"
MAIL_TRANSPORT=log
